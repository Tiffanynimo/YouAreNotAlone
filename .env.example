# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL connection string (provided automatically by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# BetterAuth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Public URL of this service (used by BetterAuth for CORS + cookie domain)
# Staging:    https://your-app-staging.up.railway.app
# Production: https://your-app.up.railway.app  (or your custom domain)
BETTER_AUTH_URL=https://your-app.up.railway.app

# Port (Railway sets this automatically, do not override in Railway)
PORT=3000
